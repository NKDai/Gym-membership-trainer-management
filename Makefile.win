OBJ      = main.o member.o MemberManagement.o GlobalFunctions.o trainer.o Sort.o Settings.o
LINKOBJ  = main.o member.o MemberManagement.o GlobalFunctions.o trainer.o Sort.o Settings.o
LIBS     = -L"D:/Dev-Cpp/TDM-GCC-64/lib" -L"D:/Dev-Cpp/TDM-GCC-64/x86_64-w64-mingw32/lib" -static-libgcc -g3
